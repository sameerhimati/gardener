# Gardener environment — copy to .env at the repo root (backend loads it via python-dotenv).
# (Named env.example instead of .env.example because a local security hook blocks
#  writing files matching .env* — rename or `cp env.example .env` as needed.)
# The app must run with ONLY ANTHROPIC_API_KEY set; everything else degrades gracefully.

# ── Required ────────────────────────────────────────────────────────────────
# Anthropic API key — console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Optional: model override ────────────────────────────────────────────────
# Main agent loop model (default: claude-sonnet-4-6)
MODEL=

# ── Optional: ClickHouse (event log + lint findings) ────────────────────────
# Leave unset → transparent fallback to data/events.jsonl / data/findings.jsonl.
# Get from ClickHouse Cloud (clickhouse.cloud) → your service → Connect → HTTPS, port 8443.
CLICKHOUSE_URL=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=

# ── Optional: Pioneer (OpenAI-compatible) for lint + distiller LLM calls ────
# Leave unset → lint/distiller use Anthropic. See docs/pioneer.md.
PIONEER_API_KEY=
PIONEER_BASE_URL=

# Fine-tuned GLiNER2 housing-preference extractor ($500 "Best Use of Pioneer").
# When set, the distiller extracts housing steering deterministically via this
# model instead of a general-LLM call (falls back to Anthropic on any miss).
# Build/train it with: python scripts/pioneer_finetune.py  (see data/pioneer_finetune.json)
GLINER_MODEL_ID=

# ── Optional: Senso / cited.md publishing (correction changelog) ────────────
# Sign up at senso.ai ($100 free credits, no card). Keys start with tgr_.
# Also requires the CLI: npm install -g @senso-ai/cli
SENSO_API_KEY=

# ── Optional garnish ────────────────────────────────────────────────────────
# Composio (composio.dev → settings → API keys)
COMPOSIO_API_KEY=
# Langfuse LLM-call tracing (cloud.langfuse.com → project settings → API keys).
# Leave unset → tracing silently no-ops; the app runs on ANTHROPIC_API_KEY alone.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# ── Web UI (goes in web/.env.local, not read by the backend) ────────────────
# Where the Next.js app finds the API (default http://localhost:8000)
NEXT_PUBLIC_API_URL=
